# ADO Wiki Editor Extension - Robot Framework Test Configuration
# Copy this file to .env and fill in your values

# ============================================
# Azure DevOps Configuration (Required)
# ============================================
ADO_ORG_URL=https://dev.azure.com/your-organization
ADO_PROJECT=your-project-name
ADO_WIKI_NAME=your-wiki-name
ADO_PAT=your-personal-access-token

# ============================================
# SSO/Login Configuration (For UI Tests)
# ============================================
SSO_USERNAME=your.email@company.com
SSO_PASSWORD=your-password-here

# ============================================
# Test Configuration
# ============================================
# Test page path in wiki (create a test page for automation)
TEST_PAGE_PATH=/Test-Automation-Page

# Base URL for local testing (extension popup/test pages)
# IMPORTANT: Robot tests expect a navigable URL (e.g. http(s)://... or file://...).
# If you omit LOCAL_TEST_URL entirely, the tests default to a safe file:// URL in
# tests/robot/resources/common.robot.
# Example (when running a local server):
# LOCAL_TEST_URL=http://localhost:8080/playground.html

# ============================================
# Browser Configuration
# ============================================
BROWSER_HEADLESS=True
BROWSER_TIMEOUT=30
BROWSER_SLOW_MO=0

# ============================================
# Extension Configuration
# ============================================
# Path to unpacked extension for loading (relative to tests/)
EXTENSION_PATH=../public

# ============================================
# Retry Configuration
# ============================================
MAX_RETRIES=3
RETRY_DELAY=2

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
