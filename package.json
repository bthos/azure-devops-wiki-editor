{
  "name": "azure-devops-wiki-editor",
  "description": "Chrome Extension enables WYSIWYG editor in Azure DevOps markdown wiki. Based on Milkdown framework (https://milkdown.dev)",
  "version": "3.0.1",
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev-build": "npm run clean && node build.mjs",
    "build": "npm run clean && cross-env NODE_ENV=production node build.mjs",
    "server": "http-server . -p 8080 -c-1",
    "version": "node scripts/sync-version.js && git add public/manifest.json",
    "commit": "git-cz",
    "prepare-commit-msg": "exec < /dev/tty && npx cz --hook || true",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch && git push --follow-tags origin main",
    "release:minor": "standard-version --release-as minor && git push --follow-tags origin main",
    "release:major": "standard-version --release-as major && git push --follow-tags origin main"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bthos/azure-devops-wiki-editor.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bthos/azure-devops-wiki-editor/issues"
  },
  "homepage": "https://github.com/bthos/azure-devops-wiki-editor#readme",
  "dependencies": {
    "@milkdown/kit": "^7.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/chrome": "^0.0.239",
    "@vitest/coverage-v8": "^4.1.4",
    "archiver": "^7.0.1",
    "commitizen": "^4.3.1",
    "cross-env": "^7.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.24.2",
    "happy-dom": "^20.9.0",
    "http-server": "^14.1.1",
    "standard-version": "^9.5.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
